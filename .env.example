# ─────────────────────────────────────────────────────────────
# CantaMe — Environment variables
# Copy each of these into:
#   • Vercel → Project → Settings → Environment Variables  (for production)
#   • a local .env.local file                              (for dev)
# ─────────────────────────────────────────────────────────────

# MiniMax — server-side music generation (also lyrics fallback if no OpenAI key)
MINIMAX_API_KEY=sk-api-your-minimax-key
MINIMAX_API_HOST=https://api.minimax.io

# OpenAI — lyrics writing (optional). If set, lyrics use OpenAI instead of
# MiniMax. OPENAI_MODEL defaults to gpt-4o-mini.
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Moneroo — real payments for credit packs (hosted checkout + webhook).
# Secret key from Moneroo Dashboard > Developers > Generate API key.
MONEROO_SECRET_KEY=your-moneroo-secret-key
# Signing secret from Moneroo Dashboard > Developers > Webhooks (verifies webhooks).
MONEROO_WEBHOOK_SECRET=your-moneroo-webhook-secret
# Billing currency (packs are priced in this). e.g. USD, XOF, EUR.
MONEROO_CURRENCY=USD

# Supabase — public values (safe to expose, used in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase — SECRET, server only (needed for DB writes + Storage uploads)
# Dashboard > Settings > API > service_role  (do NOT expose in the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
